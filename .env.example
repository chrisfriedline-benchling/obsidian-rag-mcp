# Required: OpenAI API key for embeddings
OPENAI_API_KEY=sk-your-key-here

# --- OR use Azure OpenAI instead of OpenAI ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_API_KEY=your-azure-api-key
# AZURE_OPENAI_VERSION=2024-10-21
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- OR use Amazon Bedrock (Titan Embeddings V2) instead of OpenAI/Azure ---
# No API key needed -- uses the standard AWS credential chain (SSO profile,
# env vars, instance role, etc.) via boto3.
# EMBEDDING_PROVIDER=bedrock
# AWS_PROFILE=your-bedrock-profile
# AWS_REGION=us-east-1

# Optional: Default vault path
OBSIDIAN_VAULT_PATH=./vault

# Optional: ChromaDB storage location (default: ./.vault)
CHROMA_PERSIST_DIR=./.vault

# Optional: Enable reasoning layer (default: false)
# REASONING_ENABLED=true
